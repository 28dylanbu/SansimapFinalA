                        <Region HBox.hgrow="ALWAYS"/>
                        <HBox spacing="20">
                            <Label text="Términos de Uso" style="-fx-font-family: 'Candara'; -fx-text-fill: rgba(255,255,255,0.5); -fx-font-size: 13px;"/>
                            <Label text="Privacidad" style="-fx-font-family: 'Candara'; -fx-text-fill: rgba(255,255,255,0.5); -fx-font-size: 13px;"/>
                        </HBox>
                    </HBox>
                </VBox>

            </VBox>
        </ScrollPane>
    </VBox>

