<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane fx:controller="com.example.sansimap.EmailVerificationController" style="-fx-background-color: linear-gradient(to bottom right, #cc0000, #1a0000);" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
    <VBox alignment="CENTER" maxWidth="380" maxHeight="480" spacing="20" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.5), 20, 0, 0, 0);">
        <padding>
            <Insets bottom="30" left="40" right="40" top="30"/>
        </padding>
        <HBox alignment="CENTER" spacing="5">
            <Label text="SANSI" style="-fx-font-weight: bold; -fx-font-size: 32; -fx-text-fill: #e3000f;" />
            <Label text="MAP" style="-fx-font-weight: bold; -fx-font-style: italic; -fx-font-size: 32; -fx-text-fill: #003b73;" />
        </HBox>
        <Region prefHeight="10" />
        <HBox alignment="CENTER" spacing="10">
            <TextField fx:id="box1" prefWidth="45" prefHeight="45" style="-fx-border-color: #b3b3b3; -fx-border-radius: 5; -fx-background-color: white; -fx-alignment: center; -fx-font-size: 18;" />
            <TextField fx:id="box2" prefWidth="45" prefHeight="45" style="-fx-border-color: #b3b3b3; -fx-border-radius: 5; -fx-background-color: white; -fx-alignment: center; -fx-font-size: 18;" />
            <TextField fx:id="box3" prefWidth="45" prefHeight="45" style="-fx-border-color: #b3b3b3; -fx-border-radius: 5; -fx-background-color: white; -fx-alignment: center; -fx-font-size: 18;" />
            <TextField fx:id="box4" prefWidth="45" prefHeight="45" style="-fx-border-color: #b3b3b3; -fx-border-radius: 5; -fx-background-color: white; -fx-alignment: center; -fx-font-size: 18;" />
            <TextField fx:id="box5" prefWidth="45" prefHeight="45" style="-fx-border-color: #b3b3b3; -fx-border-radius: 5; -fx-background-color: white; -fx-alignment: center; -fx-font-size: 18;" />
            <TextField fx:id="box6" prefWidth="45" prefHeight="45" style="-fx-border-color: #b3b3b3; -fx-border-radius: 5; -fx-background-color: white; -fx-alignment: center; -fx-font-size: 18;" />
        </HBox>
        <Label wrapText="true" textAlignment="CENTER" style="-fx-font-size: 13; -fx-text-fill: #666666; -fx-padding: 10 10 10 10;"
               text="Te enviamos un correo para confirmar que eres tú. Revisa tu bandeja de entrada (y la carpeta de spam por si las dudas) e introduce el código para empezar." />
        <Region prefHeight="5" />

        <Button onAction="#verificarCodigoIngresado" maxWidth="Infinity" style="-fx-background-color: #e3000f; -fx-text-fill: white; -fx-background-radius: 25; -fx-font-weight: bold; -fx-font-size: 14; -fx-padding: 12;" text="Verificar correo">
            <cursor><Cursor fx:constant="HAND" /></cursor>
        </Button>

        <Label onMouseClicked="#volverAlLogin" style="-fx-font-size: 12; -fx-text-fill: #999999; -fx-padding: 5 0 0 0;" text="Volver al inicio de sesión">
            <cursor><Cursor fx:constant="HAND" /></cursor>
        </Label>
    </VBox>
</StackPane>