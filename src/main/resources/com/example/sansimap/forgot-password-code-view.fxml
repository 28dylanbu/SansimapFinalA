<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane fx:controller="com.example.sansimap.ForgotPasswordCodeController" style="-fx-background-color: linear-gradient(to bottom right, #cc0000, #1a0000);" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">

    <VBox alignment="CENTER" maxWidth="380" maxHeight="500" spacing="15" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.5), 20, 0, 0, 0);">
        <padding>
            <Insets bottom="25" left="35" right="35" top="25" />
        </padding>

        <HBox alignment="CENTER" spacing="5">
            <Label text="SANSI" style="-fx-font-weight: bold; -fx-font-size: 32; -fx-text-fill: #e3000f;" />
            <Label text="MAP" style="-fx-font-style: italic; -fx-font-weight: bold; -fx-font-size: 32; -fx-text-fill: #003b73;" />
        </HBox>

        <Label style="-fx-font-size: 15; -fx-text-fill: #666666;" text="OLVIDE MI CONTRASEÑA" />

        <Region prefHeight="10" />

        <HBox alignment="CENTER" spacing="8">
            <TextField fx:id="box1" prefWidth="40" prefHeight="40" style="-fx-border-color: #b3b3b3; -fx-border-radius: 5; -fx-background-color: white; -fx-alignment: center; -fx-font-size: 16;" />
            <TextField fx:id="box2" prefWidth="40" prefHeight="40" style="-fx-border-color: #b3b3b3; -fx-border-radius: 5; -fx-background-color: white; -fx-alignment: center; -fx-font-size: 16;" />
            <TextField fx:id="box3" prefWidth="40" prefHeight="40" style="-fx-border-color: #b3b3b3; -fx-border-radius: 5; -fx-background-color: white; -fx-alignment: center; -fx-font-size: 16;" />
            <TextField fx:id="box4" prefWidth="40" prefHeight="40" style="-fx-border-color: #b3b3b3; -fx-border-radius: 5; -fx-background-color: white; -fx-alignment: center; -fx-font-size: 16;" />
            <TextField fx:id="box5" prefWidth="40" prefHeight="40" style="-fx-border-color: #b3b3b3; -fx-border-radius: 5; -fx-background-color: white; -fx-alignment: center; -fx-font-size: 16;" />
            <TextField fx:id="box6" prefWidth="40" prefHeight="40" style="-fx-border-color: #b3b3b3; -fx-border-radius: 5; -fx-background-color: white; -fx-alignment: center; -fx-font-size: 16;" />
        </HBox>

        <Label wrapText="true" textAlignment="CENTER" style="-fx-font-size: 11; -fx-text-fill: #666666; -fx-padding: 10 0 10 0;"
               text="¿Aún no revisaste ningún código? Revisa la bandeja de entrada, o el apartado de spam de tu email. Puedes intentar volver a enviar el código de recuperación y verificar que tu email este correctamente escrito." />

        <Button onAction="#verificarCodigoIngresado" maxWidth="Infinity" style="-fx-background-color: #e3000f; -fx-text-fill: white; -fx-background-radius: 25; -fx-font-weight: bold; -fx-font-size: 14; -fx-padding: 12;" text="Restaurar contraseña">
            <cursor><Cursor fx:constant="HAND" /></cursor>
        </Button>

        <Region prefHeight="5" />

        <VBox alignment="CENTER" spacing="10">
            <Label onMouseClicked="#corregirCorreo" style="-fx-font-size: 11; -fx-text-fill: #999999;" text="Corregir correo electrónico">
                <cursor><Cursor fx:constant="HAND" /></cursor>
            </Label>
            <Label onMouseClicked="#volverAlLogin" style="-fx-font-size: 11; -fx-text-fill: #999999;" text="Volver al inicio de sesión">
                <cursor><Cursor fx:constant="HAND" /></cursor>
            </Label>
        </VBox>

    </VBox>
</StackPane>