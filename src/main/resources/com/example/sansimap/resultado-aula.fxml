<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.ImageView?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.sansimap.ResultadoAulaController"
            style="-fx-background-color: linear-gradient(to bottom, #0a1f44, #123a7a);">

    <left>
        <VBox spacing="15"
              style="-fx-background-color: white; -fx-padding: 25; -fx-background-radius: 0 20 20 0;"
              prefWidth="260">

            <Button text="← Volver"
                    onMouseClicked="#volverBuscar"
                    style="-fx-background-color: #6c757d; -fx-text-fill: white;"/>

            <Label fx:id="infoAula"
                   text="Información del aula"
                   wrapText="true"
                   style="-fx-font-size: 14px; -fx-text-fill: #0a1f44;"/>

        </VBox>
    </left>

    <center>
        <VBox spacing="10"
              style="-fx-padding: 20;"
              alignment="CENTER">

            <ImageView fx:id="fotoUbicacion"
                       fitWidth="460"
                       fitHeight="200"
                       preserveRatio="true"
                       visible="false"/>

            <ScrollPane fitToHeight="true"
                        hbarPolicy="AS_NEEDED"
                        vbarPolicy="NEVER"
                        style="-fx-background: transparent; -fx-background-color: transparent;">
                <HBox fx:id="contenedorFotos"
                      spacing="10"
                      alignment="CENTER"/>
            </ScrollPane>

        </VBox>
    </center>

</BorderPane>