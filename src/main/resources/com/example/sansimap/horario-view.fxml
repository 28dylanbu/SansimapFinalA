<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.sansimap.HorarioController"
            style="-fx-background-color: linear-gradient(to bottom, #0a1f44, #123a7a);">

    <top>
        <VBox spacing="15" alignment="CENTER" style="-fx-padding: 30;">
            <Label text="Buscador de Disponibilidad"
                   style="-fx-font-size: 24; -fx-text-fill: white; -fx-font-weight: bold;"/>

            <HBox spacing="10" alignment="CENTER">
                <TextField fx:id="txtBusquedaAula"
                           promptText="Escriba el aula (ej: 101)"
                           style="-fx-pref-width: 250; -fx-background-radius: 10;"/>
                <Button text="Ver Horarios"
                        onAction="#procesarBusqueda"
                        style="-fx-background-color: #28a745; -fx-text-fill: white; -fx-background-radius: 10;"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true"
                    style="-fx-background: transparent; -fx-background-color: transparent;"
                    hbarPolicy="NEVER">
            <VBox fx:id="contenedorHorarios"
                  spacing="15"
                  style="-fx-padding: 20;"
                  alignment="TOP_CENTER"/>
        </ScrollPane>
    </center>

    <bottom>
        <VBox alignment="CENTER" style="-fx-padding: 15;">
            <Button text="← Volver al Menú"
                    onAction="#volverMenu"
                    style="-fx-background-color: #6c757d; -fx-text-fill: white; -fx-font-size: 14px; -fx-background-radius: 10;"/>
        </VBox>
    </bottom>

</BorderPane>