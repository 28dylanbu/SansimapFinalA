<?xml version="1.0" encoding="UTF-8"?>

<!-- Importaciones de componentes JavaFX -->
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.StackPane?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextArea?>

<?import javafx.scene.image.ImageView?>

<!--
Ventana de aulas disponibles.
Muestra una lista de aulas y una imagen del mapa.
-->

<BorderPane
        xmlns:fx="http://javafx.com/fxml"
        fx:controller="com.example.sansimap.AulasDisponiblesController"

        style="
            -fx-background-color:
            linear-gradient(to bottom, #0a1f44, #123a7a);
        ">

    <!-- ===== PANEL IZQUIERDO ===== -->
    <left>

        <!-- Barra lateral -->
        <VBox
                spacing="15"
                prefWidth="260"

                style="
                    -fx-background-color: #0a1f44;
                    -fx-padding: 25;
                    -fx-background-radius: 0 20 20 0;
                ">

            <!-- Botón para volver al menú -->
            <Button
                    text="← Volver"
                    onAction="#volverMenu"

                    style="
                        -fx-background-color: #6c757d;
                        -fx-text-fill: white;
                    "/>

            <!-- Título -->
            <Label
                    text="Aulas Disponibles"

                    style="
                        -fx-font-size: 18px;
                        -fx-text-fill: white;
                        -fx-font-weight: bold;
                    "/>

            <!-- Lista de aulas -->
            <TextArea
                    fx:id="listaAulas"

                    editable="false"
                    wrapText="true"

                    style="
                        -fx-control-inner-background: white;
                        -fx-text-fill: black;
                        -fx-font-size: 14px;
                    "/>

        </VBox>
    </left>

    <!-- ===== CONTENIDO CENTRAL ===== -->
    <center>

        <!-- Contenedor del mapa -->
        <StackPane>

            <!-- Imagen del mapa -->
            <ImageView
                    fx:id="fondo"

                    fitWidth="540"

                    preserveRatio="true"

                    smooth="true"

                    pickOnBounds="true"/>

        </StackPane>
    </center>

</BorderPane>