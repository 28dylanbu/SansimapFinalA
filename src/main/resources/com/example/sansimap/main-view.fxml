<?xml version="1.0" encoding="UTF-8"?>

<!-- Importaciones de JavaFX -->
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.image.ImageView?>

<!-- Contenedor principal -->
<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.sansimap.MainController"
            style="-fx-background-color: linear-gradient(to bottom, #0a1f44, #123a7a);">

    <!-- Panel lateral izquierdo -->
    <left>

        <!-- Menú de opciones -->
        <VBox spacing="20"
              prefWidth="260"
              style="-fx-background-color: white;
                     -fx-padding: 25;
                     -fx-background-radius: 0 20 20 0;">

            <!-- Título -->
            <Label text="Opciones de búsqueda"
                   style="-fx-font-size: 20px;
                          -fx-font-weight: bold;
                          -fx-text-fill: #0a1f44;" />

            <!-- Botón buscar aula -->
            <Button text="Buscar aula"
                    onAction="#irBuscarAula"
                    style="-fx-background-color: #d62828;
                           -fx-text-fill: white;
                           -fx-font-size: 14px;
                           -fx-background-radius: 10;" />

            <!-- Botón aulas disponibles -->
            <Button text="Aulas disponibles"
                    onAction="#irAulasDisponibles"
                    style="-fx-background-color: #003049;
                           -fx-text-fill: white;
                           -fx-font-size: 14px;
                           -fx-background-radius: 10;" />

        </VBox>

    </left>

    <!-- Parte central -->
    <center>

        <!-- Contenedor del mapa -->
        <StackPane>

            <!-- Imagen del mapa -->
            <ImageView fx:id="mapaPrincipal"
                       fitWidth="600"
                       preserveRatio="true"
                       pickOnBounds="true" />

        </StackPane>

    </center>

</BorderPane>