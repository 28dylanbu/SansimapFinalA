<?xml version="1.0" encoding="UTF-8"?>

<!-- Importaciones de componentes JavaFX -->

<?import javafx.geometry.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<!--
Ventana de Inicio de SansiMap
Muestra los botónes e imágenes correspondientes a esta parte INICIAL
-->

<StackPane style="-fx-background-color: #ffffff;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.sansimap.InicioController">

    <!-- Contenido principal desplazable -->
    <VBox>

        <!-- Barra superior COLOR BLANCO-->
        <HBox alignment="CENTER_LEFT" style="-fx-background-color: #ffffff; -fx-padding: 10 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 2);">

            <!-- Botón en la Barra Superior para abrir/cerrar el menú lateral -->
            <Button onAction="#toggleMenu" style="-fx-font-family: 'Century Gothic'; -fx-font-size: 16px; -fx-font-weight: bold; -fx-background-color: transparent; -fx-text-fill: #0a1f44;" text="☰ Menú">
                <!-- Indicador de poder interactuar -->
                <cursor>
                    <Cursor fx:constant="HAND" />
                </cursor>
            </Button>

            <!-- Espaciador(Espacio entre el botón y el texto superior) -->
            <Region HBox.hgrow="ALWAYS" />

            <!-- Texto superior -->
            <Label style="-fx-font-family: 'Candara'; -fx-text-fill: #0a1f44; -fx-font-weight: bold; -fx-font-size: 14px;" text="Universidad Mayor de San Simón - UMSS" />
        </HBox>

        <!-- Deslizador "Scroll" principal de toda la página(ARRIBA-ABAJO) -->
        <ScrollPane fx:id="scrollPrincipal" fitToWidth="true" style="-fx-background-color: #ffffff; -fx-border-color: transparent;" VBox.vgrow="ALWAYS">

            <VBox style="-fx-background-color: #ffffff;">

                <!-- Sección Principal -->
                <VBox alignment="CENTER" spacing="25" style="-fx-background-image: url('fondo.jpeg'); -fx-background-size: cover; -fx-background-color: linear-gradient(to bottom right, rgba(10,31,68,0.95), rgba(214,40,40,0.95)); -fx-background-blend-mode: multiply; -fx-padding: 80 40;">

                    <!-- Logo con Entrada Animada -->
                    <StackPane fx:id="iconoAnimado" style="-fx-max-width: 80; -fx-max-height: 80; -fx-background-radius: 20; -fx-background-color: white; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.3), 15, 0, 0, 5);">
                        <ImageView fitHeight="86" fitWidth="86" >

                                <Image url="@logo.jpeg" />

                            <!-- Marco que sostiene la imágen -->
                            <clip>
                                <Rectangle arcHeight="50" arcWidth="60" height="85" width="85" />
                            </clip>
                        </ImageView>
                    </StackPane>

                    <!-- Títulos Principales con animación de Entrada -->
                    <VBox alignment="CENTER" spacing="10">
                        <Label fx:id="tituloAnimado" style="-fx-font-family: 'Century Gothic'; -fx-font-size: 65px; -fx-font-weight: bold; -fx-text-fill: white; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.4), 15, 0, 0, 8);" text="SANSI MAP" />
                        <Label fx:id="subtituloAnimado" style="-fx-font-family: 'Candara'; -fx-font-size: 20px; -fx-text-fill: white; -fx-font-weight: bold;" text="Sistema de navegación web para la Facultad de Tecnología - UMSS" />
                        <Label fx:id="textoInferiorAnimado" style="-fx-font-family: 'Candara'; -fx-font-size: 16px; -fx-text-fill: rgba(255, 255, 255, 0.85);" text="Encuentra aulas, laboratorios y oficinas con referencias visuales en tiempo real" />
                    </VBox>

                    <!-- Botón principal de Inició de Sesión o Registro -->
                    <HBox fx:id="botonesAnimados" alignment="CENTER" spacing="20">
                        <Button onAction="#cambiarALogin" style="-fx-font-family: 'Century Gothic'; -fx-background-color: white; -fx-text-fill: #0a1f44; -fx-background-radius: 30; -fx-font-weight: bold; -fx-padding: 12 35; -fx-font-size: 15px;" text="Iniciar">
                            <!-- Indicador de poder hacer interactuar -->
                            <cursor>
                                <Cursor fx:constant="HAND" />
                            </cursor>
                        </Button>
                    </HBox>

                    <!-- Tarjetas de estadísticas -->
                    <HBox fx:id="statsAnimados" alignment="CENTER" spacing="20">
                        <!-- Tamaño de una sección -->
                        <HBox.margin>
                            <Insets top="40" />
                        </HBox.margin>

                        <VBox alignment="CENTER" style="-fx-background-color: rgba(255,255,255,0.1); -fx-background-radius: 15; -fx-border-color: rgba(255,255,255,0.3); -fx-border-radius: 15; -fx-padding: 20 40; -fx-min-width: 180;">
                            <Label style="-fx-font-family: 'Century Gothic'; -fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: white;" text="50+" />
                            <Label style="-fx-font-family: 'Candara'; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;" text="Aulas Mapeadas" />
                        </VBox>

                        <VBox alignment="CENTER" style="-fx-background-color: rgba(255,255,255,0.1); -fx-background-radius: 15; -fx-border-color: rgba(255,255,255,0.3); -fx-border-radius: 15; -fx-padding: 20 40; -fx-min-width: 180;">
                            <Label style="-fx-font-family: 'Century Gothic'; -fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: white;" text="15+" />
                            <Label style="-fx-font-family: 'Candara'; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;" text="Laboratorios" />
                        </VBox>

                        <VBox alignment="CENTER" style="-fx-background-color: rgba(255,255,255,0.1); -fx-background-radius: 15; -fx-border-color: rgba(255,255,255,0.3); -fx-border-radius: 15; -fx-padding: 20 40; -fx-min-width: 180;">
                            <Label style="-fx-font-family: 'Century Gothic'; -fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: white;" text="24/7" />
                            <Label style="-fx-font-family: 'Candara'; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;" text="Acceso Web" />
                        </VBox>
                    </HBox>
                </VBox>

                <!-- Sección del mapa -->
                <VBox alignment="CENTER" spacing="10" style="-fx-padding: 60 0; -fx-background-color: white;">
                    <Label style="-fx-font-family: 'Century Gothic'; -fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #d62828;" text="Facultad de Tecnología" />
                    <Label style="-fx-font-family: 'Candara'; -fx-text-fill: #555555; -fx-font-size: 16px; -fx-padding: 0 0 30 0;" text="Explora el mapa general de la Facultad de Tecnología UMSS con todos los edificios y espacios académicos" />

                    <HBox alignment="TOP_CENTER" spacing="30">
                        <!-- Espacio Interno donde estarán el mapa y la barra de búsqueda rápida -->
                        <padding>
                            <Insets bottom="20" left="40" right="40" />
                        </padding>

                        <StackPane fx:id="mapaContenedor" style="-fx-background-color: #f4f7f8; -fx-border-color: #0a1f44; -fx-border-width: 2; -fx-background-radius: 15; -fx-border-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.15), 15, 0, 0, 8);" HBox.hgrow="ALWAYS">
                            <Label style="-fx-font-family: 'Candara'; -fx-text-fill: #d62828;" text="Si ves esto, la ruta de mapa.png está mal escrita" />
                            <ImageView fitWidth="900" preserveRatio="true">
                                    <Image url="@mapa.png" />
                            </ImageView>
                        </StackPane>
                        <!-- Barra Lateral Derecha de Búsqueda Rápida -->
                        <VBox maxWidth="350" minWidth="300" spacing="20">

                            <VBox spacing="10" style="-fx-background-color: #d62828; -fx-padding: 25; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(214,40,40,0.4), 10, 0, 0, 5);">
                                <Label style="-fx-font-family: 'Century Gothic'; -fx-font-weight: bold; -fx-text-fill: white; -fx-font-size: 18px;" text="Búsqueda Rápida" />
                                <HBox spacing="10">
                                    <TextField promptText="Aula 301, Lab-4..." style="-fx-font-family: 'Candara'; -fx-background-radius: 8; -fx-padding: 8;" HBox.hgrow="ALWAYS" />
                                    <Button onAction="#irBuscarAula" style="-fx-font-family: 'Century Gothic'; -fx-background-color: white; -fx-text-fill: #d62828; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 15;" text="Buscar">
                                        <cursor>
                                            <Cursor fx:constant="HAND" />
                                        </cursor>
                                    </Button>
                                </HBox>
                            </VBox>
                            <!-- Barra Lateral Derecha de Edificios (Sugerencias) -->
                            <VBox spacing="12" style="-fx-background-color: #0a1f44; -fx-padding: 25; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(10,31,68,0.4), 10, 0, 0, 5);">
                                <Label style="-fx-font-family: 'Century Gothic'; -fx-font-weight: bold; -fx-text-fill: white; -fx-font-size: 18px;" text="Edificios" />
                                <Button alignment="BASELINE_LEFT" maxWidth="Infinity" onAction="#irEdificioPrincipal" style="-fx-font-family: 'Candara'; -fx-font-size: 15px; -fx-font-weight: bold; -fx-background-color: rgba(255,255,255,0.1); -fx-text-fill: white; -fx-padding: 12; -fx-background-radius: 8;" text="📍 Edificio Principal (ED-P)">
                                    <cursor><Cursor fx:constant="HAND" /></cursor>
                                </Button>
                                <Button alignment="BASELINE_LEFT" maxWidth="Infinity" onAction="#irLaboratorios" style="-fx-font-family: 'Candara'; -fx-font-size: 15px; -fx-font-weight: bold; -fx-background-color: rgba(255,255,255,0.1); -fx-text-fill: white; -fx-padding: 12; -fx-background-radius: 8;" text="📍 Laboratorios (LAB-1)">
                                    <cursor><Cursor fx:constant="HAND" /></cursor>
                                </Button>
                                <Button alignment="BASELINE_LEFT" maxWidth="Infinity" onAction="#irAulasTeoricas" style="-fx-font-family: 'Candara'; -fx-font-size: 15px; -fx-font-weight: bold; -fx-background-color: rgba(255,255,255,0.1); -fx-text-fill: white; -fx-padding: 12; -fx-background-radius: 8;" text="📍 Aulas Teóricas (AT-1)">
                                    <cursor><Cursor fx:constant="HAND" /></cursor>
                                </Button>
                            </VBox>
                        </VBox>
                    </HBox>
                </VBox>

                <!-- Sección de características principales -->
                <VBox alignment="CENTER" spacing="30" style="-fx-padding: 60 40; -fx-background-color: #f4f7f8;">
                    <VBox alignment="CENTER" spacing="5">
                        <Label style="-fx-font-family: 'Century Gothic'; -fx-text-fill: #d62828; -fx-font-weight: bold; -fx-font-size: 14px; -fx-letter-spacing: 1px;" text="⚡ Características" />
                        <Label style="-fx-font-family: 'Century Gothic'; -fx-font-size: 34px; -fx-font-weight: bold; -fx-text-fill: #0a1f44;" text="Características Principales" />
                        <Label style="-fx-font-family: 'Candara'; -fx-text-fill: #555; -fx-font-size: 16px;" text="Todo lo que necesitas para moverte por la UMSS de manera eficiente y sin complicaciones" />
                    </VBox>

                    <HBox alignment="CENTER" spacing="20">
                        <VBox prefWidth="320" spacing="15" style="-fx-background-color: white; -fx-padding: 25; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.08), 10, 0, 0, 5);">
                            <StackPane  style="-fx-background-color: #d62828; -fx-background-radius: 12; -fx-min-width: 45; -fx-min-height: 45; -fx-max-width: 45;">
                                <Label style="-fx-text-fill: white; -fx-font-size: 20px;" text="🔍" />
                            </StackPane>
                            <Label style="-fx-font-family: 'Century Gothic'; -fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: #0a1f44;" text="Búsqueda por Nombre de Aula" />
                            <Label style="-fx-font-family: 'Candara'; -fx-font-size: 14px; -fx-text-fill: #666; -fx-wrap-text: true;" text="Busca cualquier aula por su nombre o código. El sistema te mostrará su ubicación exacta con referencias visuales y fotos del lugar." />
                        </VBox>

                        <VBox prefWidth="320" spacing="15" style="-fx-background-color: white; -fx-padding: 25; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.08), 10, 0, 0, 5);">
                            <StackPane  style="-fx-background-color: #0a1f44; -fx-background-radius: 12; -fx-min-width: 45; -fx-min-height: 45; -fx-max-width: 45;">
                                <Label style="-fx-text-fill: white; -fx-font-size: 20px;" text="➤" />
                            </StackPane>
                            <Label style="-fx-font-family: 'Century Gothic'; -fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: #0a1f44;" text="Navegación Visual" />
                            <Label style="-fx-font-family: 'Candara'; -fx-font-size: 14px; -fx-text-fill: #666; -fx-wrap-text: true;" text="Recibe indicaciones visuales con fotos de referencia para llegar a tu destino sin perderte en el campus." />
                        </VBox>

                        <VBox prefWidth="320" spacing="15" style="-fx-background-color: white; -fx-padding: 25; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.08), 10, 0, 0, 5);">
                            <HBox alignment="CENTER">
                                <StackPane  style="-fx-background-color: #d62828; -fx-background-radius: 12; -fx-min-width: 45; -fx-min-height: 45; -fx-max-width: 45;">
                                    <Label style="-fx-text-fill: white; -fx-font-size: 20px;" text="🕒" />
                                </StackPane>
                                <Region HBox.hgrow="ALWAYS" />
                                <Label style="-fx-font-family: 'Century Gothic'; -fx-background-color: #fca311; -fx-text-fill: white; -fx-padding: 3 10; -fx-background-radius: 15; -fx-font-weight: bold; -fx-font-size: 11px;" text="Próximamente" />
                            </HBox>
                            <Label style="-fx-font-family: 'Century Gothic'; -fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: #0a1f44;" text="Horarios de Aulas" />
                            <Label style="-fx-font-family: 'Candara'; -fx-font-size: 14px; -fx-text-fill: #666; -fx-wrap-text: true;" text="Próximamente: Consulta la disponibilidad de aulas y laboratorios en tiempo real según los horarios de clases." />
                        </VBox>
                    </HBox>

                    <HBox alignment="CENTER" spacing="20">
                        <VBox prefWidth="320" spacing="15" style="-fx-background-color: white; -fx-padding: 25; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.08), 10, 0, 0, 5);">
                            <StackPane  style="-fx-background-color: #0a1f44; -fx-background-radius: 12; -fx-min-width: 45; -fx-min-height: 45; -fx-max-width: 45;">
                                <Label style="-fx-text-fill: white; -fx-font-size: 20px;" text="📖" />
                            </StackPane>
                            <Label style="-fx-font-family: 'Century Gothic'; -fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: #0a1f44;" text="Información Detallada" />
                            <Label style="-fx-font-family: 'Candara'; -fx-font-size: 14px; -fx-text-fill: #666; -fx-wrap-text: true;" text="Accede a información completa sobre cada espacio: capacidad, equipamiento disponible y características especiales." />
                        </VBox>

                        <VBox prefWidth="320" spacing="15" style="-fx-background-color: white; -fx-padding: 25; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.08), 10, 0, 0, 5);">
                            <StackPane  style="-fx-background-color: #d62828; -fx-background-radius: 12; -fx-min-width: 45; -fx-min-height: 45; -fx-max-width: 45;">
                                <Label style="-fx-text-fill: white; -fx-font-size: 20px;" text="📅" />
                            </StackPane>
                            <Label style="-fx-font-family: 'Century Gothic'; -fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: #0a1f44;" text="Mapa Interactivo" />
                            <Label style="-fx-font-family: 'Candara'; -fx-font-size: 14px; -fx-text-fill: #666; -fx-wrap-text: true;" text="Explora el mapa interactivo de la Facultad de Tecnología con todos los edificios, aulas y puntos de interés." />
                        </VBox>

                        <VBox prefWidth="320" spacing="15" style="-fx-background-color: white; -fx-padding: 25; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.08), 10, 0, 0, 5);">
                            <HBox alignment="CENTER_LEFT">
                                <StackPane style="-fx-background-color: #0a1f44; -fx-background-radius: 12; -fx-min-width: 45; -fx-min-height: 45;">
                                    <Label style="-fx-text-fill: white; -fx-font-size: 20px;" text="🔔" />
                                </StackPane>
                                <Region HBox.hgrow="ALWAYS" />
                                <Label style="-fx-font-family: 'Century Gothic'; -fx-background-color: #fca311; -fx-text-fill: white; -fx-padding: 3 10; -fx-background-radius: 15; -fx-font-weight: bold; -fx-font-size: 11px;" text="Próximamente" />
                            </HBox>
                            <Label style="-fx-font-family: 'Century Gothic'; -fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: #0a1f44;" text="Favoritos y Recientes" />
                            <Label style="-fx-font-family: 'Candara'; -fx-font-size: 14px; -fx-text-fill: #666; -fx-wrap-text: true;" text="Próximamente: Guarda tus aulas favoritas y accede rápidamente a tus búsquedas recientes para ahorrar tiempo." />
                        </VBox>
                    </HBox>
                </VBox>

                <!-- Sección informativa final
                     SECTOR: ¿Por qué SANSI MAP?
                 -->
                <VBox spacing="60" style="-fx-background-color: linear-gradient(to bottom right, #051433, #d62828); -fx-padding: 80 80 40 80;">
                    <HBox alignment="CENTER" spacing="50">
                        <StackPane fx:id="celularContenedor" prefHeight="500" prefWidth="300" style="-fx-background-radius: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.3), 20, 0, 0, 10);" HBox.hgrow="NEVER">
                            <ImageView fitHeight="500" fitWidth="300">
                                    <Image url="@mano.jpg" />
                                <clip>
                                    <Rectangle arcHeight="30" arcWidth="30" height="500" width="350" />
                                </clip>
                            </ImageView>
                        </StackPane>

                        <VBox alignment="CENTER_LEFT" maxWidth="500" spacing="20">
                            <Label style="-fx-font-family: 'Century Gothic'; -fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: white;" text="¿Por qué SANSI MAP?" />
                            <Label style="-fx-font-family: 'Candara'; -fx-text-fill: rgba(255,255,255,0.9); -fx-wrap-text: true; -fx-font-size: 15px;" text="SANSI MAP es el sistema web de navegación para la Facultad de Tecnología de la Universidad Mayor de San Simón. Encuentra aulas, laboratorios y oficinas con referencias visuales que te guían hasta tu destino." />

                            <VBox spacing="10">
                                <HBox spacing="10"><Label style="-fx-text-fill: white; -fx-border-color: white; -fx-border-radius: 50; -fx-padding: 0 4; -fx-font-size: 10px;" text="✔" /><Label style="-fx-font-family: 'Candara'; -fx-font-size: 15px; -fx-text-fill: white;" text="Busca aulas por nombre y código" /></HBox>
                                <HBox spacing="10"><Label style="-fx-text-fill: white; -fx-border-color: white; -fx-border-radius: 50; -fx-padding: 0 4; -fx-font-size: 10px;" text="✔" /><Label style="-fx-font-family: 'Candara'; -fx-font-size: 15px; -fx-text-fill: white;" text="Referencias visuales con fotos reales" /></HBox>
                                <HBox spacing="10"><Label style="-fx-text-fill: white; -fx-border-color: white; -fx-border-radius: 50; -fx-padding: 0 4; -fx-font-size: 10px;" text="✔" /><Label style="-fx-font-family: 'Candara'; -fx-font-size: 15px; -fx-text-fill: white;" text="Mapa interactivo de toda la facultad" /></HBox>
                                <HBox spacing="10"><Label style="-fx-text-fill: white; -fx-border-color: white; -fx-border-radius: 50; -fx-padding: 0 4; -fx-font-size: 10px;" text="✔" /><Label style="-fx-font-family: 'Candara'; -fx-font-size: 15px; -fx-text-fill: white;" text="Actualizaciones en tiempo real" /></HBox>
                                <HBox spacing="10"><Label style="-fx-text-fill: white; -fx-border-color: white; -fx-border-radius: 50; -fx-padding: 0 4; -fx-font-size: 10px;" text="✔" /><Label style="-fx-font-family: 'Candara'; -fx-font-size: 15px; -fx-text-fill: white;" text="Interfaz web accesible desde cualquier dispositivo" /></HBox>
                                <HBox spacing="10"><Label style="-fx-text-fill: white; -fx-border-color: white; -fx-border-radius: 50; -fx-padding: 0 4; -fx-font-size: 10px;" text="✔" /><Label style="-fx-font-family: 'Candara'; -fx-font-size: 15px; -fx-text-fill: white;" text="Sistema desarrollado para estudiantes UMSS" /></HBox>
                            </VBox>
                            <!-- Comentario de Recomendación -->
                            <VBox style="-fx-background-color: rgba(255,255,255,0.1); -fx-border-color: rgba(255,255,255,0.2); -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 15;">
                                <Label style="-fx-font-family: 'Candara'; -fx-font-size: 14px; -fx-text-fill: rgba(255,255,255,0.9); -fx-font-style: italic; -fx-wrap-text: true;" text="&quot;Una herramienta imprescindible para cualquier miembro de la comunidad universitaria UMSS&quot;" />
                            </VBox>
                        </VBox>
                    </HBox>
                    <!-- Sección de Navegación Visual(Descripción) -->
                    <VBox alignment="CENTER" fillWidth="false" >
                        <padding>
                            <Insets bottom="60" top="40" />
                        </padding>

                        <HBox fx:id="navegacionContenedor" alignment="CENTER" spacing="40" style="-fx-background-color: rgba(255,255,255,0.1); -fx-border-color: rgba(255,255,255,0.2); -fx-border-radius: 20; -fx-background-radius: 20; -fx-padding: 40; -fx-max-width: 1100;">
                            <VBox alignment="CENTER_LEFT" maxWidth="500" spacing="15">
                                <Label style="-fx-font-family: 'Century Gothic'; -fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: white; -fx-wrap-text: true;" text="Navegación Visual con Referencias Fotográficas" />
                                <Label style="-fx-font-family: 'Candara'; -fx-text-fill: rgba(255,255,255,0.85); -fx-wrap-text: true; -fx-font-size: 15px;" text="Con SANSI MAP, no solo ves la ubicación en el mapa. El sistema te muestra fotos reales del lugar que buscas: puertas de aulas, pasillos, escaleras y puntos de referencia. Así llegas a tu destino sin confusiones." />
                            </VBox>
                            <StackPane style="-fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.3), 15, 0, 0, 8);">
                                <ImageView fitHeight="280" fitWidth="450" >
                                        <Image url="@docente.jpg" />
                                    <clip>
                                        <Rectangle arcHeight="30" arcWidth="30" height="280" width="450" />
                                    </clip>
                                </ImageView>
                            </StackPane>
                        </HBox>
                    </VBox>
                </VBox>

                <!-- Pie de página -->
                <VBox spacing="30" style="-fx-background-color: #0a1f44; -fx-padding: 40 80;">
                    <HBox spacing="150">
                        <VBox spacing="10">
                            <!-- MODIFICACIÓN: Imagen de pinche en el título del pie de página -->
                            <HBox alignment="CENTER_LEFT" spacing="10">
