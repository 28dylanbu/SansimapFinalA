                                </ImageView>
                                <Label text="Universidad Mayor de San Simón&#10;Cochabamba, Bolivia" style="-fx-font-family: 'Candara'; -fx-text-fill: rgba(255,255,255,0.6); -fx-font-size: 13px;"/>
