<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane fx:controller="com.example.sansimap.ResetPasswordController" style="-fx-background-color: linear-gradient(to bottom right, #cc0000, #1a0000);" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">

    <VBox alignment="CENTER" maxWidth="380" maxHeight="450" spacing="18" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.5), 20, 0, 0, 0);">
        <padding>
            <Insets bottom="30" left="40" right="40" top="30" />
        </padding>

        <HBox alignment="CENTER" spacing="5">
            <Label text="SANSI" style="-fx-font-weight: bold; -fx-font-size: 32; -fx-text-fill: #e3000f;" />
            <Label text="MAP" style="-fx-font-style: italic; -fx-font-weight: bold; -fx-font-size: 32; -fx-text-fill: #003b73;" />
        </HBox>

        <Label style="-fx-font-size: 14; -fx-text-fill: #666666; -fx-padding: -5 0 10 0;" text="OLVIDE MI CONTRASEÑA" />

        <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-border-color: #b3b3b3; -fx-border-radius: 20; -fx-background-color: transparent; -fx-padding: 8 15 8 15;">
            <Label style="-fx-font-size: 16; -fx-text-fill: #808080;" text="🔒" />
            <StackPane HBox.hgrow="ALWAYS" alignment="CENTER_LEFT">
                <PasswordField fx:id="passOculto1" promptText="Nueva contraseña" style="-fx-background-color: transparent; -fx-prompt-text-fill: #999999; -fx-text-fill: #333333; -fx-padding: 0;" />
                <TextField fx:id="passVisible1" promptText="Nueva contraseña" visible="false" style="-fx-background-color: transparent; -fx-prompt-text-fill: #999999; -fx-text-fill: #333333; -fx-padding: 0;" />
            </StackPane>
            <Label fx:id="ojo1" onMouseClicked="#alternarPass1" style="-fx-font-size: 16; -fx-text-fill: #808080;" text="👁">
                <cursor><Cursor fx:constant="HAND" /></cursor>
            </Label>
        </HBox>

        <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-border-color: #b3b3b3; -fx-border-radius: 20; -fx-background-color: transparent; -fx-padding: 8 15 8 15;">
            <Label style="-fx-font-size: 16; -fx-text-fill: #808080;" text="🔒" />
            <StackPane HBox.hgrow="ALWAYS" alignment="CENTER_LEFT">
                <PasswordField fx:id="passOculto2" promptText="Confirmar nueva contraseña" style="-fx-background-color: transparent; -fx-prompt-text-fill: #999999; -fx-text-fill: #333333; -fx-padding: 0;" />
                <TextField fx:id="passVisible2" promptText="Confirmar nueva contraseña" visible="false" style="-fx-background-color: transparent; -fx-prompt-text-fill: #999999; -fx-text-fill: #333333; -fx-padding: 0;" />
            </StackPane>
            <Label fx:id="ojo2" onMouseClicked="#alternarPass2" style="-fx-font-size: 16; -fx-text-fill: #808080;" text="👁">
                <cursor><Cursor fx:constant="HAND" /></cursor>
            </Label>
        </HBox>

        <Region prefHeight="5" />

        <Button onAction="#corregirContrasena" maxWidth="Infinity" style="-fx-background-color: #e3000f; -fx-text-fill: white; -fx-background-radius: 25; -fx-font-weight: bold; -fx-font-size: 14; -fx-padding: 12;" text="Corregir contraseña">
            <cursor><Cursor fx:constant="HAND" /></cursor>
        </Button>

        <Label onMouseClicked="#volverAlLogin" style="-fx-font-size: 12; -fx-text-fill: #999999; -fx-padding: 5 0 0 0;" text="Volver al inicio de sesión">
            <cursor><Cursor fx:constant="HAND" /></cursor>
        </Label>

    </VBox>
</StackPane>